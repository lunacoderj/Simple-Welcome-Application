<?xml version="1.0" encoding="utf-8"?>
<!-- 
    GRADIENT BACKGROUND
    Deep navy to dark purple — creates a "deep space" feel
    perfect for an AI/futuristic theme
-->
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="rectangle">
    <gradient
        android:angle="160"
        android:startColor="@color/bg_primary"
        android:centerColor="#0F1338"
        android:endColor="@color/bg_secondary"
        android:type="linear" />
</shape>
